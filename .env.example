
# PostgreSQL connection
DB_HOST=db_host
DB_PORT=5432
POSTGRES_USER=authcore_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=db_name

# Application
PORT=8765

# Secret key (replace with a secure random value in production)
SECRET_KEY=your_secret_key_here

# Example DATABASE_URL (replace placeholders)
DATABASE_URL=postgresql://authcore_user:your_password_here@db:5432/authcore_db

# url for redis database
REDIS_URL=redis://redis:6379