# PostgreSQL connection
DB_HOST=db
DB_PORT=5432
POSTGRES_USER=authcore_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=authcore_db

# Application
PORT=8765

# JWT settings
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256

# Database URLs
DATABASE_URL=postgresql://authcore_user:your_password_here@db:5432/authcore_db
ASYNC_DATABASE_URL=postgresql+asyncpg://authcore_user:your_password_here@db:5432/authcore_db

# Redis
REDIS_URL=redis://redis:6379

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
ADMIN_MAIL=your-mail@example.com

# Base URL
BASE_URL=http://localhost:8765

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=your-base-url/v1/auth/google/callback